# Mobile: leave unset in local development so Metro's LAN host is detected.
# Set explicitly only for a deployed API, e.g. https://api.example.com.
# EXPO_PUBLIC_API_URL=
# API
DONE_DB_PATH=./done.sqlite3
DONE_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
DONE_CORS_ORIGIN_REGEX=https?://(?:localhost|127\.0\.0\.1|\[::1\]|10(?:\.\d{1,3}){3}|192\.168(?:\.\d{1,3}){2}|172\.(?:1[6-9]|2\d|3[01])(?:\.\d{1,3}){2})(?::\d+)?
DONE_STT_ENABLED=true
# Keep synthetic failures opt-in; set true only when presenting the recovery demo.
DONE_DEMO_FAILURES_ENABLED=false
DONE_DEMO_ENDPOINTS_ENABLED=false
DONE_PORTFOLIO_SHADOW_MODE=false
DONE_PORTFOLIO_AUTONOMY_ENABLED=false
DONE_PORTFOLIO_SHADOW_MIN_RUNS=100
DONE_PORTFOLIO_SHADOW_MAX_RECOMMENDATION_DIFF_RATE=0.01
DONE_PORTFOLIO_SHADOW_MAX_PRICE_DELTA_RATE=0.02

# OpenAI speech services (the standard key is server-only; never use EXPO_PUBLIC_*)
OPENAI_API_KEY=
DONE_TRANSCRIPTION_BASE_URL=https://api.openai.com
DONE_TRANSCRIPTION_MODEL=gpt-4o-transcribe
DONE_TRANSCRIPTION_DEFAULT_LANGUAGE=pl
DONE_TRANSCRIPTION_CONNECT_TIMEOUT_SECONDS=5
DONE_TRANSCRIPTION_REQUEST_TIMEOUT_SECONDS=120
DONE_TRANSCRIPTION_MAX_CONCURRENCY=2
DONE_TRANSCRIPTION_MAX_UPLOAD_BYTES=26214400

# OpenAI Realtime
DONE_REALTIME_ENABLED=true
DONE_REALTIME_BASE_URL=https://api.openai.com
DONE_REALTIME_MODEL=gpt-realtime-2
DONE_REALTIME_VOICE=marin
DONE_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
DONE_REALTIME_CONNECT_TIMEOUT_SECONDS=5
DONE_REALTIME_REQUEST_TIMEOUT_SECONDS=20

# Commerce execution mode:
# - demo/sandbox: deterministic local payment simulation for development
# - live: fail closed until real inventory-reservation and card-issuer adapters are configured
DONE_COMMERCE_MODE=demo

# Required in live mode. Generate a private value, for example with
# `openssl rand -hex 32`. The mobile client reads the matching local value.
DONE_API_AUTH_ENABLED=false
DONE_API_AUTH_TOKEN=
EXPO_PUBLIC_API_ACCESS_TOKEN=

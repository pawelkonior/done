{
  "name": "@done/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "build:web": "expo export --platform web",
    "test": "jest --runInBand --detectOpenHandles --forceExit"
  },
  "dependencies": {
    "@expo/metro-runtime": "57.0.3",
    "@tanstack/react-query": "5.101.2",
    "expo": "57.0.4",
    "expo-audio": "57.0.0",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "57.0.3",
    "expo-dev-client": "57.0.5",
    "expo-file-system": "57.0.0",
    "expo-haptics": "57.0.0",
    "expo-linear-gradient": "57.0.0",
    "expo-linking": "57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "57.0.4",
    "expo-speech": "57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "57.0.0",
    "lucide-react-native": "1.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2",
    "react-native-webrtc": "124.0.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.17",
    "jest-expo": "57.0.1",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    }
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
